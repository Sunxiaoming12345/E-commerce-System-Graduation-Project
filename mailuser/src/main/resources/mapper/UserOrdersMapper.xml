<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mailuser.mapper.UserOrdersMapper">
    
    <!-- 分页查询订单 -->
    <select id="PageQuery" parameterType="com.example.mailuser.dto.MyOrdersPageQueryDTO" resultType="com.example.mailuser.entity.Orders">
        SELECT * FROM orders
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据订单ID和用户ID查询订单 -->
    <select id="getOrderByIdAndUserId" parameterType="java.util.Map" resultType="com.example.mailuser.entity.Orders">
        SELECT * FROM orders
        WHERE order_id = #{orderId} AND user_id = #{userId}
    </select>
    
    <!-- 根据订单ID查询订单 -->
    <select id="getOrderById" parameterType="java.lang.Long" resultType="com.example.mailuser.entity.Orders">
        SELECT * FROM orders
        WHERE order_id = #{orderId}
    </select>
    
    <!-- 更新订单状态 -->
    <update id="updateOrderStatus" parameterType="java.util.Map">
        UPDATE orders
        SET order_status = #{orderStatus}
        WHERE order_id = #{orderId}
    </update>
    
    <!-- 更新订单支付信息 -->
    <update id="updateOrderForPayment" parameterType="java.util.Map">
        UPDATE orders
        SET order_status = #{orderStatus}, payment_method = #{paymentMethod}, pay_time = NOW()
        WHERE order_id = #{orderId}
    </update>
    
    <!-- 保存订单项 -->
    <insert id="saveOrderItem" parameterType="java.util.Map">
        INSERT INTO order_items (order_id, product_id, product_name, product_price, quantity, subtotal)
        VALUES (#{orderId}, #{productId}, #{productName}, #{productPrice}, #{quantity}, #{subtotal})
    </insert>
    
    <!-- 根据订单ID查询订单项列表 -->
    <select id="selectOrderItemsByOrderId" parameterType="java.lang.Long" resultType="com.example.mailadmin.entity.OrderItems">
        SELECT * FROM order_items
        WHERE order_id = #{orderId}
    </select>
    
    <!-- 根据订单号查询订单 -->
    <select id="selectByOrderNumber" parameterType="java.lang.String" resultType="com.example.mailuser.entity.Orders">
        SELECT * FROM orders WHERE order_number = #{orderNumber}
    </select>
    
</mapper>
